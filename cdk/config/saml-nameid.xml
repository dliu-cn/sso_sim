<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:util="http://www.springframework.org/schema/util"
       xmlns:p="http://www.springframework.org/schema/p"
       xmlns:c="http://www.springframework.org/schema/c"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
                           http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd
                           http://www.springframework.org/schema/util http://www.springframework.org/schema/util/spring-util.xsd"
       default-init-method="initialize"
       default-destroy-method="destroy">

    <!-- Emit the user's UPN as the NameID using persistent format.
         UPN is a stable per-user identifier (see attribute-resolver.xml) that does
         not change if the user's email is reassigned, so federated identity in
         Cognito (custom:externalUserId) and the SLO secondary index both survive
         email renames.

         Cognito maps NameID to userName which has a 128-char limit; the default
         transient generator seals a UUID producing ~168 chars, so we override.

         Format must be persistent: Cognito always sends persistent format in
         LogoutRequests, and Shibboleth's SLO secondary index key includes the
         format — any mismatch causes SessionNotFound. -->
    <util:list id="shibboleth.SAML2NameIDGenerators">
        <bean parent="shibboleth.SAML2AttributeSourcedGenerator"
            p:omitQualifiers="true"
            p:format="urn:oasis:names:tc:SAML:2.0:nameid-format:persistent"
            p:attributeSourceIds="#{ {'upn'} }" />
        <ref bean="shibboleth.SAML2TransientGenerator" />
    </util:list>

    <util:list id="shibboleth.SAML1NameIdentifierGenerators">
        <ref bean="shibboleth.SAML1TransientGenerator" />
    </util:list>

</beans>
