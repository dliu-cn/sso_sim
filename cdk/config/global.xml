<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:p="http://www.springframework.org/schema/p"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd"
       default-init-method="initialize"
       default-destroy-method="destroy">

    <!--
        Declare a server-side MemoryStorageService and wire it as the IdP session store.

        Shibboleth 3.4.x in the Docker image defaults to a client-side (cookie-based)
        storage service (isServerSide() = false).  Overriding the system bean
        shibboleth.StorageService in-place does not work because Shibboleth protects
        system bean definitions from user-space redefinition.

        Instead we define a fresh bean under a new name and point idp.session.StorageService
        to it.  The session manager resolves that property across all loaded beans
        (system + conf/global.xml), so it finds this definition.

        With server-side storage:
          - StorageBackedIdPSession.addSPSession() succeeds (isServerSide() = true)
          - trackSPSessions=true populates the secondary index
          - SLO secondary lookup finds the SP session → UnknownPrincipal is resolved

        MemoryStorageService is in-process, so sessions are lost on container restart,
        but that is acceptable for the SSO-sim test environment.
    -->
    <bean id="shibboleth.ServerSideStorage"
        class="org.opensaml.storage.impl.MemoryStorageService"
        p:cleanupInterval="PT10M" />

</beans>
