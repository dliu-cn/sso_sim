<?xml version="1.0" encoding="UTF-8"?>
<!--
    Cognito Service Provider metadata for Shibboleth.
    __COGNITO_SP_ENTITY_ID__ and __COGNITO_SP_ACS_URL__ are substituted by startup.sh.
-->
<md:EntityDescriptor
    xmlns:md="urn:oasis:names:tc:SAML:2.0:metadata"
    entityID="__COGNITO_SP_ENTITY_ID__">

    <md:SPSSODescriptor
        AuthnRequestsSigned="false"
        WantAssertionsSigned="false"
        protocolSupportEnumeration="urn:oasis:names:tc:SAML:2.0:protocol">

        <!-- Cognito SP signing certificate — used to verify signed LogoutRequests from Cognito -->
        <md:KeyDescriptor use="signing">
            <ds:KeyInfo xmlns:ds="http://www.w3.org/2000/09/xmldsig#">
                <ds:X509Data>
                    <ds:X509Certificate></ds:X509Certificate>
                </ds:X509Data>
            </ds:KeyInfo>
        </md:KeyDescriptor>

        <!-- Cognito SLO endpoint — where Shibboleth sends the LogoutResponse after processing logout -->
        <!-- Cognito's /saml2/logout only accepts POST; HTTP-Redirect (GET) returns 400 Allow: POST -->
        <md:SingleLogoutService
            Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST"
            Location="__COGNITO_SP_SLO_URL__"/>

        <md:AssertionConsumerService
            Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST"
            Location="__COGNITO_SP_ACS_URL__"
            index="1"/>

    </md:SPSSODescriptor>

</md:EntityDescriptor>
