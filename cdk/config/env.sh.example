# Environment variables for manually re-running scripts on the EC2 instance.
# Copy to env.sh and fill in the actual values from your cdk deploy outputs.
export IDP_HOSTNAME=test-idp.yourdomain.com
export S3_BUCKET=sso-sim-shibboleth-config-YOUR_ACCOUNT_ID
export COGNITO_POOL_ID=us-east-1_XXXXXXXXX
export COGNITO_REGION=us-east-1
export COGNITO_SP_ENTITY_ID=urn:amazon:cognito:sp:us-east-1_XXXXXXXXX
export COGNITO_SP_ACS_URL=https://yourapp.auth.us-east-1.amazoncognito.com/saml2/idpresponse
