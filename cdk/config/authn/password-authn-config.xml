<?xml version="1.0" encoding="UTF-8"?>
<!--
    Password authentication config — uses htpasswd file instead of LDAP.
    The default Shibboleth config expects LDAP; this overrides it with
    the flat-file htpasswd validator for test use.
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:util="http://www.springframework.org/schema/util"
       xmlns:c="http://www.springframework.org/schema/c"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
                           http://www.springframework.org/schema/util http://www.springframework.org/schema/util/spring-util.xsd"
       default-init-method="initialize"
       default-destroy-method="destroy">

    <util:list id="shibboleth.authn.Password.Validators">
        <bean class="net.shibboleth.idp.authn.impl.HTPasswdCredentialValidator"
              c:resource="%{idp.home}/conf/users.htpasswd"/>
    </util:list>

</beans>
